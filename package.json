{
  "name": "ace-os",
  "version": "1.0.0",
  "description": "Academic Companion Engine OS - A Linux-based educational operating system for Raspberry Pi (currently minimal: shell + Settings + AI)",
  "private": true,
  "workspaces": [
    "backend",
    "frontend/desktop-shell",
    "frontend/shared",
    "frontend/apps/ai",
    "frontend/apps/focus",
    "frontend/apps/home",
    "frontend/apps/settings"
  ],
  "scripts": {
    "dev:shell": "npm run dev --workspace=@ace/desktop-shell",
    "dev:backend": "npm run dev --workspace=@ace/backend",
    "dev": "npm-run-all --parallel dev:backend dev:shell",
    "build": "npm-run-all build:shared build:shell build:apps build:backend",
    "build:shared": "npm run build --workspace=@ace/shared",
    "build:shell": "npm run build --workspace=@ace/desktop-shell",
    "build:apps": "npm run build --workspaces --if-present",
    "build:backend": "npm run build --workspace=@ace/backend",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "verify": "npm-run-all typecheck test",
    "preview:shell": "npm run preview --workspace=@ace/desktop-shell",
    "raspi:info": "bash raspberry-pi/system/info.sh",
    "raspi:blink": "node raspberry-pi/gpio/scripts/blink.js 17",
    "raspi:ollama": "bash system/linux-config/install-ollama.sh",
    "later:restore:frontend": "echo 'move apps back: mv later/apps/{home,tasks,planner,focus,subjects,statistics} frontend/apps/' && echo 'then add entries back to frontend/shared/src/apps-registry.ts and update vite + tsconfig aliases'",
    "later:restore:os": "echo 'mv later/os ./os'",
    "shell:nextjs:dev":      "npm --prefix frontend/nextjs      run dev",
    "shell:nextjs:build":    "npm --prefix frontend/nextjs      run build",
    "shell:rust-iced:run":   "cargo run  --manifest-path frontend/rust-iced/Cargo.toml --release",
    "shell:rust-iced:check": "cargo check --manifest-path frontend/rust-iced/Cargo.toml",
    "shell:rust-slint:run":  "cargo run  --manifest-path frontend/rust-slint/Cargo.toml --release",
    "shell:rust-slint:check":"cargo check --manifest-path frontend/rust-slint/Cargo.toml",
    "shell:cpp-qt:build":    "cmake -S frontend/cpp-qt -B frontend/cpp-qt/build && cmake --build frontend/cpp-qt/build",
    "shell:cpp-qt:run":      "frontend/cpp-qt/build/ace-cpp-qt",
    "shell:java-javafx:run": "mvn -B -f frontend/java-javafx/pom.xml javafx:run",
    "shell:c-gtk4:build":    "make -C frontend/c-gtk4",
    "shell:c-gtk4:run":      "frontend/c-gtk4/ace-c-gtk4",
    "shells:verify":         "node scripts/verify-shells.mjs",
    "shells:dev-all":        "bash scripts/dev-all.sh",
    "os:boot:render":        "bash -c 'mkdir -p system/boot/plymouth/theme && rsvg-convert -w 1024 -h 600 system/boot/splash.svg -o system/boot/plymouth/theme/splash.png && rsvg-convert -w 800 -h 480 system/boot/splash.svg -o system/boot/plymouth/theme/splash-800.png'",
    "os:boot:install-local": "sudo bash system/boot/install-plymouth.sh",
    "os:kernel:build":       "bash system/linux-config/kernel/build-kernel.sh",
    "os:kernel:check":       "bash -c 'set -e; cd system/linux-config/kernel; test -f bcm2711_aceos_defconfig.fragment && test -x build-kernel.sh'",
    "os:image:build":        "bash -c 'docker build -t ace-os-builder -f later/os/build/Dockerfile .'"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "vite": "^5.4.21"
  },
  "allowScripts": {
    "esbuild@0.21.5": true,
    "better-sqlite3@11.10.0": true,
    "esbuild@0.28.1": true
  }
}
