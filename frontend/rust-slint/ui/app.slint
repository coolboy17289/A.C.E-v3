// A.C.E OS · Rust + Slint front-end (declarative UI).
//
// Phase 0 of the TypeScript → native migration (see docs/MIGRATION.md).
// This file extends the MVP three-label + Refresh layout into a
// touch-launcher shell with three regions mirroring the React
// Dashboard.tsx layout:
//
//   ┌─────────────────────────────────────────┐
//   │ header strip   ·  user name             │  64 px
//   ├─────────────────────────────────────────┤ ← accent strip 4 px
//   │                                          │
//   │ body · welcome + endpoint status         │  fill
//   │                                          │
//   │                                          │
//   ├─────────────────────────────────────────┤
//   │ 🏠 Home   ✅ Tasks   ⚙️ Settings   ⏱️    │  96 px
//   └─────────────────────────────────────────┘
//
// Touch story: every launcher tile is a 120×72 rectangle with a
// `TouchArea` child (Slint's pointer-and-touch primitive). The
// `clicked` signal propagates up to `root.app-tile-clicked(app.id)`
// which Rust handles to update the accent strip + body caption.
//
// `slint::include_modules!()` (called from main.rs) generates a
// strong-typed `AppWindow` from this file. The `apps` property is
// hard-coded here in sync with `frontend/shared/src/apps-registry.ts`
// — the two are kept identical by the upcoming
// `frontend/shared/tests/registry-parity.test.ts` (Phase 2).

export struct AppTile {
    id: string,
    name: string,
    icon: string,
    accent: string,
}

export component AppWindow inherits Window {
    title: "A.C.E OS · Slint";
    width: 800px;
    height: 480px;
    background: #0b1020;

    in-out property <string> backend-text: "—";
    in-out property <string> user-text:    "—";
    in-out property <string> fetched-text: "never";
    in-out property <string> error-text:   "";
    in-out property <bool>   loading:      false;

    in-out property <string> selected-app-id: "";
    in-out property <string> selected-app-accent: "#3da8ff";

    in-out property <[AppTile]> apps: [
        { id: "home",     name: "Home",     icon: "🏠", accent: "#3da8ff" },
        { id: "tasks",    name: "Tasks",    icon: "✅", accent: "#8a5cff" },
        { id: "settings", name: "Settings", icon: "⚙️",  accent: "#94a3b8" },
        { id: "focus",    name: "Focus",    icon: "⏱️", accent: "#34d399" },
    ];

    callback refresh-clicked();
    callback app-tile-clicked(string);

    VerticalLayout {
        padding: 0;
        spacing: 0;

        // ─── HEADER ────────────────────────────────────────────────
        Rectangle {
            height: 64px;
            background: #172248;

            HorizontalLayout {
                padding: 16px;
                spacing: 16px;
                alignment: start;

                Text {
                    text: "A.C.E";
                    font-size: 22px;
                    font-weight: 800;
                    color: #3da8ff;
                    vertical-alignment: center;
                }

                Rectangle {
                    width: 1px;
                    height: 32px;
                    background: #2b3a63;
                }

                Text {
                    text: "Hi, " + root.user-text;
                    font-size: 16px;
                    color: #e6ebff;
                    vertical-alignment: center;
                }
            }
        }

        // ─── ACCENT STRIP (6 px under header) ──────────────────────
        // 6 px rather than 3 px so the colour change is visible on
        // 800×480 DSI panels where 3 px ghosts backlit TFTs. The
        // active tile's accent drives this strip; the rest of the
        // chrome stays palette-neutral to keep the colour as a
        // distinct "where am I" cue.
        Rectangle {
            height: 6px;
            background: root.selected-app-accent;
        }

        // ─── BODY (fills available height) ─────────────────────────
        Rectangle {
            background: #0e1632;

            VerticalLayout {
                padding: 32px;
                alignment: center;
                spacing: 8px;

                Text {
                    text: "A.C.E OS";
                    font-size: 36px;
                    font-weight: 700;
                    color: #e6ebff;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Touch launcher · Rust + Slint";
                    font-size: 13px;
                    color: #94a3b8;
                    horizontal-alignment: center;
                }

                Rectangle { height: 20px; }

                // Endpoint-status block — keeps the MVP wiring on-screen
                // so a developer who boots this with `npm run dev:backend`
                // running sees live data without needing to re-architecture.
                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;

                    Text {
                        text: "Backend:";
                        font-size: 12px;
                        color: #94a3b8;
                    }
                    Text {
                        text: root.backend-text;
                        font-size: 13px;
                        color: #e6ebff;
                    }
                }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;

                    Text {
                        text: "Last fetched:";
                        font-size: 12px;
                        color: #94a3b8;
                    }
                    Text {
                        text: root.fetched-text;
                        font-size: 13px;
                        color: #e6ebff;
                    }
                }

                Rectangle { height: 12px; }

                refresh-btn := Button {
                    text: root.loading ? "Refreshing…" : "Refresh";
                    enabled: !root.loading;
                    clicked => { root.refresh-clicked(); }
                }

                if root.error-text != "" : Text {
                    text: "Error: " + root.error-text;
                    color: #ff5e6c;
                    font-size: 12px;
                    horizontal-alignment: center;
                }
            }
        }

        // ─── LAUNCHER ROW ──────────────────────────────────────────
        Rectangle {
            height: 96px;
            background: #172248;

            HorizontalLayout {
                padding: 12px;
                spacing: 12px;
                alignment: center;

                for app in root.apps : LauncherTile {
                    icon: app.icon;
                    label: app.name;
                    accent: app.accent;
                    selected: app.id == root.selected-app-id;
                    clicked => { root.app-tile-clicked(app.id); }
                }
            }
        }
    }
}

component LauncherTile inherits Rectangle {
    // TODO(kiosk-a11y) — Slint's `TouchArea` does not expose a
    // keyboard-focus model or an `aria-current` equivalent. The
    // React design system (covered by the prior CHANGELOG's keyboard
    // accessibility bullet) has both. When a Slint focus ring + an
    // `aria-current`-style "selected" affordance become available
    // (or once we wrap the tiles in a webview for keyboard nav),
    // wire them here. For Phase 0 the touch-only kiosk is the
    // intended primary input, so this is acceptable; flagging the
    // gap in code so Phase 2+ picks it up.

    in property <string> icon;
    in property <string> label;
    in property <string> accent;
    in property <bool>   selected;
    callback clicked();

    // 120×72: kiosk-floor touch target. The accent border + invert
    // on selection give the user clear focus feedback even on a
    // cheap DSI panel where the highlight colour is the only signal.
    // `has-hover` is a Slint 1.x Rectangle property that becomes
    // accessible when a `TouchArea` is a child; it gives us a cheap
    // press-state highlight without needing to wire any callbacks.
    height: 72px;
    width: 120px;

    background: self.selected ? self.accent : (self.pressed ? #2c3a64 : #1c2545);
    border-radius: 12px;
    border-width: 2px;
    border-color: self.accent;

    VerticalLayout {
        padding: 6px;
        alignment: center;
        spacing: 2px;

        Text {
            text: self.icon;
            font-size: 28px;
            horizontal-alignment: center;
        }
        Text {
            text: self.label;
            font-size: 13px;
            font-weight: 600;
            color: self.selected ? #08111e : #e6ebff;
            horizontal-alignment: center;
        }
    }

    TouchArea {
        clicked => { self.clicked(); }
    }
}
