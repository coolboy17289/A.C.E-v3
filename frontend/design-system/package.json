{
  "name": "@ace/design-system",
  "version": "1.0.0",
  "description": "A.C.E OS touch-first design system. Large-target primitives (>=64px) for kiosk-on-back-of-screen usage where the user's hand often covers the surface.",
  "type": "module",
  "private": true,
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme": "./src/theme.ts",
    "./spacing": "./src/spacing.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "react": "^18.3.1",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "react": "^18.3.1"
  }
}
